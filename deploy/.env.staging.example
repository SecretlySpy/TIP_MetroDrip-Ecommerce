# Copy this file to deploy/.env.staging and replace every placeholder before
# starting the stack. The real file is gitignored and must be chmod 600 on Linux.

# Public DNS and certificate registration. STAGING_HOST must be a bare hostname.
STAGING_HOST=staging.example.com
CADDY_EMAIL=operator@example.com
STAGING_HTTP_PORT=80
STAGING_HTTPS_PORT=443

# Django security values. Startup rejects this placeholder, keys shorter than 50
# characters, and low-diversity values.
DJANGO_SECRET_KEY=replace-with-a-unique-random-django-secret
DJANGO_ALLOWED_HOSTS=staging.example.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://staging.example.com

# MySQL values. Startup rejects the app-password placeholder, values shorter than
# 16 characters, and low-diversity values. Use distinct random hexadecimal strings.
MYSQL_DATABASE=metrodrip_staging
MYSQL_USER=metrodrip
MYSQL_PASSWORD=replace-with-a-random-app-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-random-root-password

# Set both seed flags to 1 for the A-4 acceptance preview. Set them back to 0
# after the catalog storefront supersedes the temporary read-only seed page.
STAGING_SEED_DEMO=1
STAGING_SEED_PREVIEW_ENABLED=1

# Production-like staging always uses HTTPS. A value of 1 is reserved only for
# isolated localhost smoke tests where Caddy/TLS is intentionally bypassed.
STAGING_ALLOW_INSECURE_HTTP=0
