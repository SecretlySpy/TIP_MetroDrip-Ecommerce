# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/

# Django
staticfiles/
media/
db.sqlite3
backups/

# Secrets — never commit environment files. Named examples remain versioned so
# operators know every required variable without seeing a real credential.
.env
.env.*
deploy/.env.staging
!*.example
!deploy/*.example

# Tooling caches
.pytest_cache/
.ruff_cache/
.coverage
htmlcov/

# Editors / OS
.vscode/
.idea/
Thumbs.db
.DS_Store
