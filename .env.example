# Copy to .env for local development. NEVER commit .env.
# Values below match docker-compose.yml for a zero-config local start.

DJANGO_SECRET_KEY=change-me
MYSQL_DATABASE=metrodrip
MYSQL_USER=metrodrip
MYSQL_PASSWORD=metrodrip
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# --- Payments (D-2/D-3). Without PAYMONGO_SECRET_KEY, development uses the
# mocked checkout completion (MOCK_PAYMENTS auto-enables in dev only).
# PAYMONGO_SECRET_KEY=
# PAYMONGO_WEBHOOK_SECRET=

# --- Enhancement-tier APIs (checkout never depends on these):
# SEMAPHORE_API_KEY=
# SEMAPHORE_SENDER_NAME=MetroDrip
# GOOGLE_MAPS_API_KEY=

# --- Staff alert recipients (comma-separated; empty disables the email leg):
# LOW_STOCK_ALERT_RECIPIENTS=
# CONTACT_ALERT_RECIPIENTS=
# DJANGO_DEFAULT_FROM_EMAIL=MetroDrip <no-reply@metrodrip.example>
